{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "轻盘",
  "version": "0.1.0",
  "identifier": "com.qingpan.desktop",
  "build": {
    "beforeDevCommand": "npm run desktop:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run desktop:build",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "轻盘 · AI 空间防火墙",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Utility",
    "shortDescription": "AI驱动的本地空间分析工具",
    "longDescription": "读取本机应用与存储元数据，使用AI解释空间占用，并提供只读的安全处理建议。",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  }
}
